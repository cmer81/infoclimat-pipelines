# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=infoclimat-pipelines
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Copernicus CDS (climato + observed)
CDS_API_URL=https://cds.climate.copernicus.eu/api
CDS_API_KEY=

# Open-Meteo (forecast)
OPENMETEO_BASE_URL=https://map-tiles.open-meteo.com

# Météo-France portail-api (AROME-OM forecast)
# Créer une app sur https://portail-api.meteofrance.fr/ puis souscrire à
# l'API "PaquetAROME-OM". La valeur est le `application_id` long-lived,
# déjà encodé en base64 (forme client_id:client_secret). Le pipeline
# l'utilise en Authorization: Basic <X> pour récupérer un bearer OAuth2.
MF_APPLICATION_ID=

# Logging
RUST_LOG=info
